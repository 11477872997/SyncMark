<!DOCTYPE html>
<html lang="zh-CN">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SyncMark</title>
  <link rel="stylesheet" href="popup.css">
</head>

<body>
  <div class="container">
    <!-- 头部 -->
    <div class="header">
      <svg class="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
      </svg>
      <h1>SyncMark</h1>
    </div>

    <!-- 主内容区域：左右分栏 -->
    <div class="main-content">
      <!-- 左侧：状态区域 -->
      <div class="left-panel">
        <!-- 同步方式选择 -->
        <div class="sync-options">
      <div class="option-card">
        <svg class="option-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2">
          <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
          <polyline points="17 21 17 13 7 13 7 21"></polyline>
          <polyline points="7 3 7 8 15 8"></polyline>
        </svg>
        <div class="option-info">
          <div class="option-number" id="bookmarkCount">0</div>
          <div class="option-label">本地书签</div>
        </div>
        <div class="unsync-badge" id="unsyncBadge" style="display: none;">
          <span id="unsyncCount">0</span>
        </div>
      </div>

      <div class="option-card">
        <svg class="option-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2">
          <path
            d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z">
          </path>
        </svg>
        <div class="option-info">
          <div class="option-number">Gist</div>
          <div class="option-label" id="syncPlatform">存储方式</div>
        </div>
      </div>

      <!-- 自动同步 -->
      <div class="option-card auto-sync-card">
        <div class="option-info">
          <div class="auto-sync-header">
            <span>自动同步</span>
            <span class="auto-sync-badge" id="autoSyncBadge">每天一次</span>
          </div>
          <div class="auto-sync-desc" id="autoSyncDesc">实时同步各端书签数据一致性</div>
        </div>
        <label class="toggle-switch">
          <input type="checkbox" id="autoSyncToggle">
          <span class="toggle-slider"></span>
        </label>
      </div>
    </div>

    <!-- 同步状态 -->
    <div class="sync-status">
      <div class="status-item">
        <span class="status-label">最后快照</span>
        <span class="status-badge success" id="statusBadge">同步成功</span>
      </div>
      <div class="status-item">
        <span class="status-label">上次同步</span>
        <span class="status-time" id="lastSyncTime">-</span>
      </div>
      <div class="status-notice" id="statusNotice">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="16" x2="12" y2="12"></line>
          <line x1="12" y1="8" x2="12.01" y2="8"></line>
        </svg>
        <span id="noticeText">首次同步完成，已上传本书签至远端</span>
      </div>
    </div>
    <!-- 立即同步按钮 -->
    <button class="sync-button" id="syncButton">
      <svg class="sync-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
        stroke-width="2">
        <polyline points="23 4 23 10 17 10"></polyline>
        <polyline points="1 20 1 14 7 14"></polyline>
        <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
      </svg>
      立即同步
    </button>

    <!-- 配置区域 -->
    <div class="config-section" id="configSection">
      <div class="config-header">
        <span class="config-title">⚙️ 同步配置</span>
      </div>

      <!-- 平台选择 -->
      <div class="config-group">
        <label class="config-label">同步平台</label>
        <div class="platform-tabs">
          <button class="platform-tab active" data-platform="github">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
            GitHub
          </button>
          <button class="platform-tab" data-platform="gitee">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
            </svg>
            Gitee
          </button>
        </div>
      </div>

      <!-- Token 输入 -->
      <div class="config-group">
        <label class="config-label">Access Token</label>

        <!-- 授权登录按钮 -->
        <button class="oauth-login-btn" id="oauthLoginBtn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
          </svg>
          <span id="oauthBtnText">授权登录</span>
        </button>

        <div class="divider-text">或手动输入</div>

        <div class="token-input-group">
          <input type="password" class="config-input" id="tokenInput" placeholder="输入您的 Token">
          <button class="oauth-quick-btn" id="oauthQuickBtn" title="快速获取">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
              <polyline points="15 3 21 3 21 9"></polyline>
              <line x1="10" y1="14" x2="21" y2="3"></line>
            </svg>
          </button>
        </div>
        <div class="config-help" id="tokenHelp">
          需要 <code>gist</code> 权限
        </div>
      </div>

      <!-- 同步频率 -->
      <div class="config-group">
        <label class="config-label">同步频率</label>
        <select class="config-select" id="syncIntervalSelect">
          <option value="60">每小时</option>
          <option value="360">每6小时</option>
          <option value="720">每12小时</option>
          <option value="1440" selected>每天一次</option>
        </select>
      </div>

      <!-- 保存按钮 -->
      <button class="save-config-btn" id="saveConfigBtn">保存配置</button>
    </div>

    <!-- 底部 -->
    <div class="footer">
      <div class="version">V1.0.1</div>
    </div>
  </div>

  <script src="popup.js"></script>
</body>

</html>