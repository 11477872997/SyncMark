{
  "manifest_version": 3,
  "name": "SyncMark",
  "version": "1.0.1",
  "description": "同步书签到 GitHub Gist 或 Gitee，跨设备管理您的书签",
  "permissions": [
    "bookmarks",
    "storage",
    "alarms",
    "identity"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "https://gist.github.com/*",
    "https://gitee.com/*",
    "https://github.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
